{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zebra Label Tool",
  "version": "0.1.0",
  "identifier": "dev.devopsofchaos.zebralabeltool",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Zebra Label Tool",
        "width": 1080,
        "height": 760,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
